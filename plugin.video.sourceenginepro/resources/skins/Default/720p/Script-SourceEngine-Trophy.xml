<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="10500">
    <defaultcontrol>3010</defaultcontrol>
    <allowoverlay>true</allowoverlay>
    <!-- Bottom-right corner (720p base: 1280x720). Kodi scales to 1080p/4K. -->
    <coordinates>
        <left>680</left>
        <top>480</top>
    </coordinates>
    <controls>
        <!-- Solid dark panel: animate on open/close (control-level works when window-level doesn't) -->
        <control type="image">
            <posx>0</posx>
            <posy>0</posy>
            <width>580</width>
            <height>220</height>
            <texture>white.png</texture>
            <colordiffuse>EE000000</colordiffuse>
            <animation effect="fade" start="0" end="100" time="300">WindowOpen</animation>
            <animation effect="slide" start="350,0" end="0,0" time="400" easing="out">WindowOpen</animation>
            <animation effect="fade" start="100" end="0" time="250">WindowClose</animation>
            <animation effect="slide" start="0,0" end="350,0" time="300" easing="in">WindowClose</animation>
        </control>

        <control type="label" id="3010">
            <posx>20</posx>
            <posy>16</posy>
            <width>540</width>
            <height>72</height>
            <font>font13_title</font>
            <align>left</align>
            <aligny>top</aligny>
            <label></label>
            <textcolor>FFFFFFFF</textcolor>
            <wrapmultiline>true</wrapmultiline>
            <animation effect="fade" start="0" end="100" time="300" delay="50">WindowOpen</animation>
            <animation effect="slide" start="350,0" end="0,0" time="400" delay="50" easing="out">WindowOpen</animation>
            <animation effect="fade" start="100" end="0" time="250">WindowClose</animation>
            <animation effect="slide" start="0,0" end="350,0" time="300" easing="in">WindowClose</animation>
        </control>

        <control type="label" id="3011">
            <posx>20</posx>
            <posy>88</posy>
            <width>540</width>
            <height>120</height>
            <font>font12</font>
            <align>left</align>
            <aligny>top</aligny>
            <label></label>
            <textcolor>FFFFFFFF</textcolor>
            <wrapmultiline>true</wrapmultiline>
            <animation effect="fade" start="0" end="100" time="300" delay="80">WindowOpen</animation>
            <animation effect="slide" start="350,0" end="0,0" time="400" delay="80" easing="out">WindowOpen</animation>
            <animation effect="fade" start="100" end="0" time="250">WindowClose</animation>
            <animation effect="slide" start="0,0" end="350,0" time="300" easing="in">WindowClose</animation>
        </control>
    </controls>
</window>
