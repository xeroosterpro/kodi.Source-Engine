<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="plugin.video.sourceenginepro" name="Source Engine Pro" version="1.1.1" provider-name="XeroosterPro">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests" version="2.25.1"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="plugin.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.service" library="service.py" start="startup"/>
        <extension point="kodi.addon.metadata">
            <summary>Automated Emby/Jellyfin Quality Picker</summary>
            <description>Source Engine Pro automatically picks the highest fidelity source across your Emby and Jellyfin servers. Features include automatic login, backup server failover, a 13-signal confidence funnel for accurate episode matching, and a full scoring pipeline for video/audio quality.</description>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="repository.jellyfin.kodi" name="Kodi Jellyfin Addons" version="1.0.0" provider-name="null_pointer,angelblue05,sualfred,im85288,xnappo">
        <requires>
            <import addon="xbmc.addon" version="12.0.0"/>
        </requires>
        <extension point="xbmc.addon.repository" name="Kodi Jellyfin Repository">
            <dir>
                <info compressed="false">https://repo.jellyfin.org/releases/client/kodi/addons.xml</info>
                <checksum>https://repo.jellyfin.org/releases/client/kodi/addons.xml.md5</checksum>
                <datadir zip="true">https://repo.jellyfin.org/releases/client/kodi</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Kodi Jellyfin Addon Repository</summary>
            <description>Official repository for JellyCon and other Jellyfin Kodi addons.</description>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="repository.embycon" name="EmbyCon Addons" version="0.0.2" provider-name="faush01">
        <requires>
            <import addon="xbmc.addon" version="12.0.0"/>
        </requires>
        <extension point="xbmc.addon.repository" name="EmbyCon Repository">
            <dir minversion="20.999.0">
                <info compressed="false">https://faush01.github.io/embycon_kodi_repo/repo/release/v21_omega/addons.xml</info>
                <checksum>https://faush01.github.io/embycon_kodi_repo/repo/release/v21_omega/addons.xml.md5</checksum>
                <datadir zip="true">https://faush01.github.io/embycon_kodi_repo/repo/release/v21_omega/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>EmbyCon Addon Repository</summary>
            <description>Official repository for EmbyCon — the lightweight Emby browser for Kodi.</description>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="repository.jurialmunkey" name="jurialmunkey Alpha Repository" version="3.4" provider-name="jurialmunkey">
        <extension point="xbmc.addon.repository" name="jurialmunkey Alpha Repository">
            <dir minversion="20.9.1">
                <info compressed="false">https://raw.githubusercontent.com/jurialmunkey/repository.jurialmunkey/master/omega/zips/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/jurialmunkey/repository.jurialmunkey/master/omega/zips/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/jurialmunkey/repository.jurialmunkey/master/omega/zips/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>jurialmunkey Alpha Repository</summary>
            <description>Official repository for TMDb Helper and other jurialmunkey Kodi addons.</description>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="repository.xeroosterpro" name="XeroosterPro - Source Engine Pro" version="1.0.0" provider-name="xeroosterpro">
        <extension point="xbmc.addon.repository" name="XeroosterPro - Source Engine Pro">
            <info compressed="false">https://xeroosterpro.github.io/kodi.Source-Engine/addons.xml</info>
            <checksum>https://xeroosterpro.github.io/kodi.Source-Engine/addons.xml.md5</checksum>
            <datadir zip="true">https://xeroosterpro.github.io/kodi.Source-Engine/</datadir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>XeroosterPro - Source Engine Pro Repository</summary>
            <platform>all</platform>
        </extension>
    </addon>
</addons>
