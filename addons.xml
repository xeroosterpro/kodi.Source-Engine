<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="plugin.video.sourceenginepro" name="Source Engine Pro" version="1.1.6" provider-name="XeroosterPro">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="script.module.requests" version="2.25.1" />
            <import addon="plugin.video.themoviedb.helper" version="0.0.1" optional="true" />
            <import addon="plugin.video.jellycon" version="0.0.1" optional="true" />
            <import addon="plugin.video.embycon" version="0.0.1" optional="true" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="plugin.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.service" library="service.py" start="startup" />
        <extension point="xbmc.addon.metadata">
            <summary>Automated Emby/Jellyfin Quality Picker</summary>
            <description>Source Engine Pro automatically logs in and picks the highest fidelity media source available across your private servers.</description>
            <platform>all</platform>
            <assets>
                <icon>resources/icon.png</icon>
            </assets>
        </extension>
    </addon>
    <addon id="repository.xeroosterpro" name="XeroosterPro - Source Engine Pro" version="1.0.0" provider-name="xeroosterpro">
        <extension point="xbmc.addon.repository" name="XeroosterPro - Source Engine Pro">
            <dir minversion="20.0.0">
                <info compressed="false">https://xeroosterpro.github.io/kodi.Source-Engine/addons.xml</info>
                <checksum>https://xeroosterpro.github.io/kodi.Source-Engine/addons.xml.md5</checksum>
                <datadir zip="true">https://xeroosterpro.github.io/kodi.Source-Engine/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>XeroosterPro - Source Engine Pro Repository</summary>
            <description>Official repository for Source Engine Pro by XeroosterPro.</description>
            <platform>all</platform>
        </extension>
    </addon>
</addons>
