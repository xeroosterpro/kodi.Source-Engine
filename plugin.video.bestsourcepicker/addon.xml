<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.bestsourcepicker" name="Source Engine Pro" version="1.0.0" provider-name="Elias">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="plugin.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="startup"/>
    
    <extension point="kodi.addon.metadata">
        <summary>Automated Emby/Jellyfin Quality Picker</summary>
        <description>Source Engine Pro automatically logs in and picks the highest fidelity media source available across your private servers.</description>
        <platform>all</platform>
        <assets>
            <icon>resources/icon.png</icon>
        </assets>
    </extension>
</addon>
